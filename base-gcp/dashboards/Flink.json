                "legendTemplate": "",
                "measures": [],
                "plotType": "LINE",
                "sort": [],
                "targetAxis": "Y1",
                "timeSeriesQuery": {
                  "outputFullDuration": false,
                  "prometheusQuery": "sum by (job_name) (flink_jobmanager_job_uptime) / (60 * 1000)\n",
                  "unitOverride": "min"
